# -----------------------------------------------------------------------------
# FIREBASE - CLIENT SDK CONFIGURATION
# -----------------------------------------------------------------------------
# These values are used in the frontend to initialize the Firebase Client SDK.
# They are safe to expose publicly.
# You can get these from your Firebase project settings -> General -> Your apps -> SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# FIREBASE - ADMIN SDK CONFIGURATION (BACKEND)
# -----------------------------------------------------------------------------
# These values are used in the backend to initialize the Firebase Admin SDK.
# These MUST be kept secret and should never be exposed to the client.
# You can get these from your Firebase project settings -> Service accounts -> Generate new private key.

# The project ID from your service account file.
FIREBASE_PROJECT_ID=
# The client email from your service account file.
FIREBASE_CLIENT_EMAIL=
# The private key from your service account file.
# IMPORTANT: Enclose the entire key in double quotes ("") and replace all literal newlines with \n.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"


# -----------------------------------------------------------------------------
# GOOGLE MAPS API KEY (BACKEND)
# -----------------------------------------------------------------------------
# This key is used for server-side requests to Google Maps APIs (e.g., Places API).
# Keep this key secret.
GOOGLE_MAPS_API_KEY=
